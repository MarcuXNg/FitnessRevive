<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <title>BMI</title>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <!-- boostrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <!-- font -->
    <link href="https://fonts.googleapis.com/css?family=Muli:300,400,500,600,700,800,900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Oswald:300,400,500,600,700&display=swap" rel="stylesheet">
    <link rel='stylesheet' type='text/css' media='screen' href="css/bmi.css">
</head>
<body>
  <header>
    <%- include('../../header/header.ejs'); %>
  </header>
    <h1>BMI Calculation</h1>
        <!-- BMI Calculation Start -->
        <div class="container-fluid position-relative bmi my-5">
            <div class="container">
                <div class="row px-3 align-items-center">
                    <div class="col-md-6">
                        <div class="pr-md-3 d-none d-md-block">
                            <h4 id="heading4" class="text-primary">Body Mass Index </h4>
                            <h4 class="display-4 text-black font-weight-bold mb-4">What is BMI?</h4>
                            <p class="m-0 text-black">The body mass index (BMI) is a measure that uses your height and weight to work out </p>
                            <p class="m-0 text-black">if your weight is healthy. The BMI calculation divides an adult's weight in kilograms by their height in metres squared.</p>
                        </div>
                    </div>
                    <div class="col-md-6 bg-secondary py-5 rounded-3">
                        <div class="py-5 px-3">
                            <h1 class="mb-4 text-white">Calculate your BMI</h1>
                            <form>
                                <div class="form-row">
                                    <div id="myDiv" class="col form-group my-2">
                                        <input id="weight" type="number" class="form-control custom-placeholder form-control-lg bg-dark text-white" placeholder="Weight (KG)">
                                        <p id="weightNoti">Please enter your weight.</p>
                                    </div>
                                    <div id="heightNoInput" class="col form-group my-2">
                                        <input id="height" type="number" class="form-control custom-placeholder form-control-lg bg-dark text-white" placeholder="Height (CM)">
                                        <p id="heightNoti">Please enter your weight.</p>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col form-group my-2">
                                        <input type="number" class="form-control custom-placeholder form-control-lg bg-dark text-white" placeholder="Age">
                                    </div>
                                    <div class="col form-group mb-3">
                                        <select class="custom-select custom-select-lg bg-dark text-white rounded-2 border-light">
                                            <option class="GenderOption">Gender</option>
                                            <option value="1">Male</option>
                                            <option value="2">Female</option>
                                            <option value="3">Other</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="col">
                                        <button type ="button" onclick="bmicalculate()" class="btn btn-lg btn-block btn-dark border-light">
                                            Calculate Now
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <script src ="js/bmicalculate.js"></script>
        <!-- BMI Calculation End -->    
</body>
</html>    
    
