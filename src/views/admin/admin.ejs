<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <!-- boostrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"
    integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous" />
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL"
    crossorigin="anonymous"></script>

  <!-- fonts -->
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons+Sharp" rel="stylesheet">
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap"
    rel="stylesheet" />
  <link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <!-- css -->
  <link rel="stylesheet" href="css/admin.css">
  <link rel='stylesheet' type='text/css' media='screen' href="css/header.css">
  <title>Admin</title>
</head>

<body>
  <!-- <header><%- include('../header/header.ejs'); %></header> -->
  <div class="container my-5">
    <!-- Sidebar Section-->
    <aside>
      <div class="toggle d-flex justify-content-between align-items-center">
        <div class="logo d-flex">
          <img src="images/logo.png" alt="">
          <h2>REVIVE<br><span class="success">FITNESS</span></h2>
        </div>
        <div class="close d-none" id="close-btn">
          <span class="material-symbols-outlined">
            close
          </span>
        </div>
      </div>
      <div class="sidebar d-flex flex-column position-relative">
        <a class="d-flex align-items-center position-relative text-decoration-none" href="#">
          <span class="material-symbols-outlined">
            dashboard
          </span>
          <h3>Dashboard</h3>
        </a>
        <a class="d-flex align-items-center position-relative text-decoration-none" href="#">
          <span class="material-symbols-outlined">
            person_outline
          </span>
          <h3>User</h3>
        </a>
        <a class="d-flex align-items-center position-relative text-decoration-none active" href="#" class="active">
          <span class="material-icons-sharp">
            insights
          </span>
          <h3>Analytics</h3>
        </a>
        <a class="d-flex align-items-center position-relative text-decoration-none" href="#">
          <span class="material-icons-sharp">
            mail_outline
          </span>
          <h3>Tickets</h3>
          <span class="message-count">27</span>
        </a>
        <a class="d-flex align-items-center position-relative text-decoration-none" href="#">
          <span class="material-icons-sharp">
            report_gmailerrorred
          </span>
          <h3>Reports</h3>
        </a>
        <a class="d-flex align-items-center position-relative text-decoration-none" href="#">
          <span class="material-symbols-outlined">
            person_outline
          </span>
          <h3>Settings</h3>
        </a>
        <a class="d-flex align-items-center position-relative text-decoration-none" href="#">
          <span class="material-icons-sharp">
              add
          </span>
          <h3>New Login</h3>
        </a>
      <a class="d-flex align-items-center text-decoration-none" href="#">
          <span class="material-icons-sharp">
              logout
          </span>
          <h3>Logout</h3>
      </a>
      </div>
    </aside>
    <!-- End of Sidebar Section -->

    <!-- Main Content -->
    <main>
      <h1>Analytics</h1>
      <!-- Analyses -->
      <div class="analyse d-grid">
        <div class="overall">
          <div class="status d-flex align-items-center justify-content-between">
            <div class="info">
              <h3>Users</h3>
              <h1>15,000</h1>
            </div>
            <div class="progress custom-progress position-relative">
              <svg>
                <circle cx="38" cy="38" r="36"></circle>
              </svg>
              <div class="percentage position-absolute d-flex align-items-center justify-content-center">
                <p>+81%</p>
              </div>
            </div>
          </div>
        </div>
        <div class="visits">
          <div class="status d-flex align-items-center justify-content-between">
            <div class="info">
              <h3>Site Visit</h3>
              <h1>1,000</h1>
            </div>
            <div class="progress custom-progress position-relative">
              <svg>
                <circle cx="38" cy="38" r="36"></circle>
              </svg>
              <div class="percentage position-absolute d-flex align-items-center justify-content-center">
                <p>-48%</p>
              </div>
            </div>
          </div>
        </div>
        <div class="searches">
          <div class="status d-flex align-items-center justify-content-between">
            <div class="info">
              <h3>Searches</h3>
              <h1>14,000</h1>
            </div>
            <div class="progress custom-progress position-relative">
              <svg>
                <circle cx="38" cy="38" r="36"></circle>
              </svg>
              <div class="percentage position-absolute d-flex align-items-center justify-content-center">
                <p>+20%</p>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!--  End of Analyses-->

      <!-- New Users Section -->
      <div class="new-users">
        <h2>New Users</h2>
        <div class="user-list d-flex justify-content-around flex-wrap">
          <div class="user d-flex flex-column align-items-center justify-content-center">
            <img src="images/logo.png">
            <h2>Jack</h2>
            <p>Joined at 11/11/2023</p>
          </div>
          <div class="user d-flex flex-column align-items-center justify-content-center">
            <img src="images/logo.png">
            <h2>Jack</h2>
            <p>Joined at 11/11/2023</p>
          </div>
          <div class="user d-flex flex-column align-items-center justify-content-center">
            <img src="images/logo.png">
            <h2>Jack</h2>
            <p>Joined at 11/11/2023</p>
          </div>
          <div class="user d-flex flex-column align-items-center justify-content-center">
            <a class="border d-flex align-items-center position-relative text-decoration-none" href="#">
              <span class="material-icons-sharp">
                  add
              </span>
            </a>
            <h2>More</h2>
            <p>New User</p>
          </div>
        </div>
      </div>
      <!-- End of New Users Section -->

    </main>
    <!-- End of Main Content -->

    <div class="right-section">
      <div class="nav d-flex justify-content-end">
        <!-- <button class="d-none" id="menu-btn">
          <span class="material-icons-sharp">
            menu
          </span>
        </button> -->
        <div id="dark-mode" class="dark-mode d-flex justify-content-between align-items-center">
          <span class="material-icons-sharp active d-flex align-items-center justify-content-center">
            light_mode
          </span>
          <span class="material-icons-sharp d-flex align-items-center justify-content-center">
            dark_mode
          </span>
        </div>
        <div class="profile d-flex text-align-right">
          <div class="info">
            <p>Hey, <b>Reza</b></p>
            <small class="text-muted">Admin</small>
          </div>
          <div class="profile-photo">
            <img src="images/logo.png">
          </div>
        </div>
      </div>
    </div>
  </div>
  <div>
    <table class="table table-hover table-bordered">
      <tbody>
        <tr>
          <th scope="row">#</th>
          <th scope="row">ID</th>
          <td>Username</td>
          <td>Email</td>
          <td>Joined At</td>
          <td>Actions</td>
          <!-- <td>
                      <button class="btn btn-warning">Edit</button>
                      <button class="btn btn-danger">Delete</button>
                  </td> -->
        </tr>
      </tbody>
    </table>
  </div>
  <script type="module" src="js/admin.js"></script>
  <script type="module" src="js/darkmode.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
</body>

</html>